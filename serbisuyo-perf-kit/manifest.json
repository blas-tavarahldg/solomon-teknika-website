  "shortcuts": [
    {
      "name": "Browse Services",
      "short_name": "Services",
      "description": "Browse available services in your area",
      "url": "/services",
      "icons": [
        {
          "src": "/images/shortcut-services-96x96.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "My Bookings",
      "short_name": "Bookings",
      "description": "View and manage your service bookings",
      "url": "/bookings",
      "icons": [
        {
          "src": "/images/shortcut-bookings-96x96.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "My Reviews",
      "short_name": "Reviews",
      "description": "View and manage your reviews",
      "url": "/reviews",
      "icons": [
        {
          "src": "/images/shortcut-reviews-96x96.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    }
  ],
  "share_target": {
    "action": "/share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "media",
          "accept": ["image/*", "video/*"]
        }
      ]
    }
  },
  "protocol_handlers": [
    {
      "protocol": "web+serbisuyo",
      "url": "/protocol?url=%s"
    }
  ]
}
